<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add Branch Code to res.partner.bank form -->
    <record id="view_res_partner_bank_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.bank.form.jinasena.branch</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_form"/>
        <field name="arch" type="xml">
            <field name="bank_id" position="after">
                <field name="x_branch_code"
                       placeholder="e.g. 050"
                       help="3-digit CBC branch code for SLIPS transfers."/>
            </field>
        </field>
    </record>

    <!-- Action: Employee Bank Accounts (filtered to employees only) -->
    <record id="action_employee_bank_accounts" model="ir.actions.act_window">
        <field name="name">Employee Bank Accounts</field>
        <field name="res_model">res.partner.bank</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_id.employee_ids', '!=', False)]</field>
        <field name="context">{}</field>
    </record>

    <!-- Menu: Payroll > Configuration > Employee Bank Accounts -->
    <menuitem id="menu_employee_bank_accounts"
              name="Employee Bank Accounts"
              parent="hr_payroll.menu_payroll_configuration"
              action="action_employee_bank_accounts"
              sequence="30"/>

</odoo>
